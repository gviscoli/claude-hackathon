# ── Provider: scegli UNO dei due blocchi ──────────────────────────────────────

# Opzione A — Anthropic API diretta
# ANTHROPIC_API_KEY=your-api-key-here

# Opzione B — AWS Bedrock (decommentare tutte le righe)
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=                          # opzionale, solo per credenziali temporanee
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ── App settings ──────────────────────────────────────────────────────────────
CLAIMS_DATA_DIR=src/data
MAX_AUTO_APPROVE_AMOUNT=50000
FRAUD_SCORE_THRESHOLD=0.7
CONFIDENCE_THRESHOLD=0.6
